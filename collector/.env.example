MONITOR_API_URL=http://api:3001
MONITOR_API_KEY=replace-with-shared-collector-key
SERVER_ID=00000000-0000-0000-0000-000000000000
SQL_SERVER_HOST=sqlserver
SQL_SERVER_PORT=1433
SQL_AUTH_TYPE=sql
SQL_USERNAME=sqlmonitor_svc
SQL_PASSWORD=Your_strong_Password123
SQL_ENTRA_TENANT_ID=
SQL_ENTRA_CLIENT_ID=
SQL_ENTRA_CLIENT_SECRET=
SQL_DATABASE=master
SQL_ENCRYPT=true
SQL_TRUST_SERVER_CERT=true
COLLECTION_INTERVAL_SECONDS=60

# Optional feature toggles to reduce noise during UI-first testing
COLLECT_QUERY_STORE=true
COLLECT_BACKUP_FAILURES=true
COLLECT_AGENT_JOBS=true

# Suppress repeat errors with same message for this many minutes
ERROR_LOG_THROTTLE_MINUTES=30
